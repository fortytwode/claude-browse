#!/usr/bin/env python3
"""
Resume a Claude Code session from any folder.

Looks up the session's original working directory and spawns claude --resume
in that folder automatically.

Usage:
    claude-resume <session-id>          # Resume by exact session ID
    claude-resume <keyword> [keyword2]  # Search sessions, pick one, resume
    claude-resume --last                # Pick from 10 most recent sessions
    claude-resume --yolo <session-id>   # Resume with --dangerously-skip-permissions
    claude-resume --yolo aditi          # Search + resume with skip permissions

Any flags after -- are passed through to claude:
    claude-resume aditi -- --model sonnet --verbose

Examples:
    claude-resume 95bc9af0-bc05-4940-bf1b-20777bc5c64c
    claude-resume aditi
    claude-resume --yolo aditi
    claude-resume "modelo 720"
    claude-resume --last
"""

import sys
import os
import json
import glob
import subprocess
from datetime import datetime, timezone, timedelta


SESSIONS_DIR = os.path.expanduser("~/.claude/projects")


def get_session_info(jsonl_path):
    """Extract session metadata from a session file."""
    first_user_msg = None
    session_id = None
    timestamp = None
    cwd = None
    name = None
    msg_count = 0

    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                try:
                    data = json.loads(line.strip())
                except json.JSONDecodeError:
                    continue

                msg = data.get("message", data)
                msg_type = data.get("type", "")

                if msg_type == "summary":
                    name = data.get("sessionName")

                if not session_id and data.get("sessionId"):
                    session_id = data.get("sessionId")
                if not cwd and data.get("cwd"):
                    cwd = data.get("cwd")
                if not timestamp and data.get("timestamp"):
                    timestamp = data.get("timestamp")

                if msg.get("role") == "user":
                    msg_count += 1
                    if not first_user_msg:
                        content = msg.get("content", "")
                        if isinstance(content, list):
                            for c in content:
                                if isinstance(c, dict) and c.get("text"):
                                    first_user_msg = c["text"]
                                    break
                        elif isinstance(content, str) and len(content) > 3:
                            first_user_msg = content
                elif msg.get("role") == "assistant":
                    msg_count += 1
    except Exception:
        return None

    return {
        "path": jsonl_path,
        "session_id": session_id,
        "first_msg": (first_user_msg or "")[:150],
        "timestamp": timestamp,
        "cwd": cwd,
        "name": name,
        "msg_count": msg_count,
    }


def find_session_by_id(session_id):
    """Find a session file by its session ID."""
    pattern = os.path.join(SESSIONS_DIR, "*", "*.jsonl")
    for filepath in glob.glob(pattern):
        if "/subagents/" in filepath:
            continue
        try:
            with open(filepath, "r") as f:
                # Only read the first 50 lines to find sessionId quickly
                for i, line in enumerate(f):
                    if i > 50:
                        break
                    try:
                        data = json.loads(line.strip())
                        if data.get("sessionId") == session_id:
                            return get_session_info(filepath)
                    except json.JSONDecodeError:
                        continue
        except Exception:
            continue
    return None


def _extract_user_text(jsonl_path):
    """Extract only user message text from a session file (lowercased).

    Searches user messages only, avoiding false matches from system context
    (CLAUDE.md, tool results, cwd paths) that inflate results.
    """
    parts = []
    with open(jsonl_path, "r") as f:
        for line in f:
            try:
                data = json.loads(line.strip())
            except json.JSONDecodeError:
                continue
            msg = data.get("message", data)
            if msg.get("role") != "user":
                continue
            content = msg.get("content", "")
            if isinstance(content, str):
                parts.append(content)
            elif isinstance(content, list):
                for c in content:
                    if isinstance(c, dict) and c.get("text"):
                        parts.append(c["text"])
    return " ".join(parts).lower()


def search_sessions(keywords, cwd_filter=None):
    """Search all session files for keywords."""
    pattern = os.path.join(SESSIONS_DIR, "*", "*.jsonl")
    all_files = glob.glob(pattern)
    main_sessions = [f for f in all_files if "/subagents/" not in f]

    results = []
    keywords_lower = [k.lower() for k in keywords]

    for filepath in main_sessions:
        try:
            user_text = _extract_user_text(filepath)
        except Exception:
            continue

        if all(kw in user_text for kw in keywords_lower):
            info = get_session_info(filepath)
            if info and info["first_msg"]:
                if cwd_filter and not (info.get("cwd") or "").startswith(cwd_filter):
                    continue
                results.append(info)

    results.sort(key=lambda x: x.get("timestamp") or "", reverse=True)
    return results


def get_recent_sessions(count=10, cwd_filter=None):
    """Get the N most recent sessions."""
    pattern = os.path.join(SESSIONS_DIR, "*", "*.jsonl")
    all_files = glob.glob(pattern)
    main_sessions = [f for f in all_files if "/subagents/" not in f]
    main_sessions.sort(key=lambda f: os.path.getmtime(f), reverse=True)

    results = []
    for filepath in main_sessions[:count * 4]:
        info = get_session_info(filepath)
        if info and info["first_msg"]:
            if cwd_filter and not (info.get("cwd") or "").startswith(cwd_filter):
                continue
            results.append(info)
        if len(results) >= count:
            break

    results.sort(key=lambda x: x.get("timestamp") or "", reverse=True)
    return results


def format_date(ts):
    """Format an ISO timestamp into a readable date."""
    if not ts:
        return "unknown"
    try:
        dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        diff = now - dt

        if diff.total_seconds() < 3600:
            mins = int(diff.total_seconds() / 60)
            return f"{mins}m ago"
        elif diff.total_seconds() < 86400:
            hours = int(diff.total_seconds() / 3600)
            return f"{hours}h ago"
        elif diff.days < 7:
            return f"{diff.days}d ago"
        else:
            return dt.strftime("%b %d, %Y")
    except Exception:
        return ts[:10]


def format_cwd(cwd):
    """Shorten the working directory for display."""
    if not cwd:
        return "?"
    home = os.path.expanduser("~")
    if cwd.startswith(home):
        return "~" + cwd[len(home):]
    return cwd


def display_and_pick(results):
    """Display results and let the user pick one. Returns the chosen session info."""
    if not results:
        print("No sessions found.")
        sys.exit(1)

    if len(results) == 1:
        r = results[0]
        print(f"Found 1 session: [{format_date(r['timestamp'])}] {r['first_msg']}")
        print(f"  Folder: {format_cwd(r['cwd'])}")
        print()
        return r

    print(f"Found {len(results)} session(s):\n")
    for i, r in enumerate(results, 1):
        date = format_date(r["timestamp"])
        folder = format_cwd(r["cwd"])
        name = f' "{r["name"]}"' if r.get("name") else ""
        print(f"  {i}. [{date}]{name} ({r['msg_count']} msgs)")
        print(f"     {folder}")
        print(f"     {r['first_msg']}")
        print()

    # Prompt for selection
    while True:
        try:
            choice = input(f"Pick a session (1-{len(results)}), or q to quit: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)

        if choice.lower() == "q":
            sys.exit(0)

        try:
            idx = int(choice) - 1
            if 0 <= idx < len(results):
                return results[idx]
            else:
                print(f"  Please enter 1-{len(results)}")
        except ValueError:
            print(f"  Please enter 1-{len(results)}")


def resume_session(session_info, extra_flags=None):
    """Resume a session in its original working directory."""
    cwd = session_info.get("cwd")
    sid = session_info.get("session_id")

    if not cwd or not os.path.isdir(cwd):
        print(f"Error: original folder no longer exists: {cwd}")
        print(f"You can try: claude --resume {sid}")
        sys.exit(1)

    cmd = ["claude", "--resume", sid] + (extra_flags or [])
    print(f"Resuming in {format_cwd(cwd)}...")
    os.chdir(cwd)
    os.execvp("claude", cmd)


def is_session_id(s):
    """Check if a string looks like a UUID session ID."""
    # UUID format: 8-4-4-4-12 hex chars
    parts = s.split("-")
    if len(parts) == 5:
        lengths = [len(p) for p in parts]
        if lengths == [8, 4, 4, 4, 12]:
            return all(c in "0123456789abcdef" for p in parts for c in p.lower())
    return False


def main():
    args = sys.argv[1:]

    if not args:
        print("Usage: claude-resume <session-id>")
        print("       claude-resume <keyword> [keyword2 ...]")
        print("       claude-resume --last")
        print("       claude-resume --yolo <session-id|keyword>")
        print("       claude-resume --here <keyword>")
        print()
        print("Options:")
        print("  --yolo    Resume with --dangerously-skip-permissions")
        print("  --here    Only sessions started in the current directory (or subdirs)")
        print("  --last    Pick from 10 most recent sessions")
        print("  --        Pass remaining flags through to claude")
        print()
        print("Examples:")
        print("  claude-resume 95bc9af0-bc05-4940-bf1b-20777bc5c64c")
        print("  claude-resume aditi")
        print("  claude-resume --yolo aditi")
        print("  claude-resume --here rummy")
        print('  claude-resume "modelo 720"')
        print("  claude-resume --last")
        print("  claude-resume aditi -- --model sonnet")
        sys.exit(1)

    # Split on -- to extract passthrough flags
    extra_flags = []
    if "--" in args:
        split_idx = args.index("--")
        extra_flags = args[split_idx + 1:]
        args = args[:split_idx]

    # Handle --yolo
    if "--yolo" in args:
        args.remove("--yolo")
        extra_flags.append("--dangerously-skip-permissions")

    # Handle --here (filter to current working directory)
    cwd_filter = None
    if "--here" in args:
        args.remove("--here")
        cwd_filter = os.getcwd()

    if not args and not extra_flags:
        print("Error: no session ID or keywords provided.")
        sys.exit(1)

    # Handle --last
    if args and args[0] == "--last":
        count = int(args[1]) if len(args) > 1 else 10
        results = get_recent_sessions(count, cwd_filter=cwd_filter)
        session = display_and_pick(results)
        resume_session(session, extra_flags)
        return

    # Single argument that looks like a session ID
    if len(args) == 1 and is_session_id(args[0]):
        info = find_session_by_id(args[0])
        if info:
            resume_session(info, extra_flags)
        else:
            print(f"Session not found: {args[0]}")
            sys.exit(1)
        return

    # Otherwise, treat as keyword search
    results = search_sessions(args, cwd_filter=cwd_filter)
    session = display_and_pick(results)
    resume_session(session, extra_flags)


if __name__ == "__main__":
    main()
