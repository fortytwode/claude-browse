#!/usr/bin/env python3
"""
Interactive Claude Code session browser.

Browse all sessions in a fuzzy-searchable list with a preview pane.
Arrow keys to navigate, type to filter, Enter to resume.

Keybindings (shown in header):
    Enter    Resume session
    Ctrl-Y   Resume with --dangerously-skip-permissions (yolo mode)
    Esc      Quit

Usage:
    claude-browse              # Browse recent 100 sessions
    claude-browse --all        # Browse ALL sessions
    claude-browse --here       # Only sessions from the current directory
"""

import sys
import os
import json
import glob
import subprocess
import tempfile
from datetime import datetime, timezone, timedelta

SESSIONS_DIR = os.path.expanduser("~/.claude/projects")
DEFAULT_LIMIT = 100


def get_session_info(jsonl_path):
    """Extract session metadata from a session file."""
    first_user_msg = None
    session_id = None
    timestamp = None
    cwd = None
    name = None
    msg_count = 0

    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                try:
                    data = json.loads(line.strip())
                except json.JSONDecodeError:
                    continue

                msg = data.get("message", data)
                msg_type = data.get("type", "")

                if msg_type == "summary":
                    name = data.get("sessionName")

                if not session_id and data.get("sessionId"):
                    session_id = data.get("sessionId")
                if not cwd and data.get("cwd"):
                    cwd = data.get("cwd")
                if not timestamp and data.get("timestamp"):
                    timestamp = data.get("timestamp")

                if msg.get("role") == "user":
                    msg_count += 1
                    if not first_user_msg:
                        content = msg.get("content", "")
                        if isinstance(content, list):
                            for c in content:
                                if isinstance(c, dict) and c.get("text"):
                                    first_user_msg = c["text"]
                                    break
                        elif isinstance(content, str) and len(content) > 3:
                            first_user_msg = content
                elif msg.get("role") == "assistant":
                    msg_count += 1
    except Exception:
        return None

    return {
        "path": jsonl_path,
        "session_id": session_id,
        "first_msg": (first_user_msg or "").replace("\n", " ").strip()[:200],
        "timestamp": timestamp,
        "cwd": cwd,
        "name": name,
        "msg_count": msg_count,
    }


def format_date(ts):
    """Format an ISO timestamp compactly."""
    if not ts:
        return "???"
    try:
        dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        diff = now - dt

        if diff.total_seconds() < 3600:
            return f"{int(diff.total_seconds() / 60)}m ago"
        elif diff.total_seconds() < 86400:
            return f"{int(diff.total_seconds() / 3600)}h ago"
        elif diff.days < 365:
            return dt.strftime("%-b %d")
        else:
            return dt.strftime("%b %Y")
    except Exception:
        return ts[:10]


def folder_name(cwd):
    """Extract the meaningful folder name from a cwd path."""
    if not cwd:
        return "?"
    home = os.path.expanduser("~")
    if cwd.startswith(home):
        rel = cwd[len(home):].strip("/")
    else:
        rel = cwd

    # Strip common prefixes to get to the meaningful part
    for prefix in ["team-operations/clients/", "team-operations/content-marketing/",
                   "team-operations/team-planning/", "team-operations/team-management/",
                   "team-operations/sales", "team-operations/"]:
        if rel.startswith(prefix):
            remainder = rel[len(prefix):].strip("/")
            # If there's a meaningful remainder, use it; otherwise use the prefix's last part
            if remainder:
                return remainder.split("/")[0]
            else:
                return prefix.rstrip("/").rsplit("/", 1)[-1]

    # For paths outside team-operations, use last component
    return rel.rstrip("/").rsplit("/", 1)[-1] if "/" in rel else rel


def full_folder(cwd):
    """Full folder path for search matching."""
    if not cwd:
        return ""
    home = os.path.expanduser("~")
    if cwd.startswith(home):
        return "~" + cwd[len(home):]
    return cwd


def get_sessions(limit=DEFAULT_LIMIT, cwd_filter=None):
    """Get sessions sorted by recency."""
    pattern = os.path.join(SESSIONS_DIR, "*", "*.jsonl")
    all_files = glob.glob(pattern)
    main_sessions = [f for f in all_files if "/subagents/" not in f]
    main_sessions.sort(key=lambda f: os.path.getmtime(f), reverse=True)

    results = []
    for filepath in main_sessions[:limit * 3]:
        info = get_session_info(filepath)
        if info and info["first_msg"]:
            if cwd_filter and not (info.get("cwd") or "").startswith(cwd_filter):
                continue
            results.append(info)
        if len(results) >= limit:
            break

    results.sort(key=lambda x: x.get("timestamp") or "", reverse=True)
    return results


def write_preview_script(sessions, script_path):
    """Write a helper script that fzf calls to generate previews.

    Shows the LAST user messages (most recent on top) so the user
    can see where the conversation ended up.
    """
    mapping = {s["session_id"]: s["path"] for s in sessions if s.get("session_id")}

    script = f"""#!/usr/bin/env python3
import sys
import json
import os

MAPPING = {json.dumps(mapping)}
MAX_PREVIEW = 20  # show up to 20 messages

def get_preview(session_id):
    path = MAPPING.get(session_id)
    if not path or not os.path.exists(path):
        print("Session file not found.")
        return

    all_messages = []
    msg_num = 0
    cwd = None
    timestamp = None
    name = None
    total_user = 0

    with open(path, "r") as f:
        for line in f:
            try:
                data = json.loads(line.strip())
            except json.JSONDecodeError:
                continue

            msg = data.get("message", data)
            msg_type = data.get("type", "")

            if msg_type == "summary" and data.get("sessionName"):
                name = data.get("sessionName")
            if not cwd and data.get("cwd"):
                cwd = data.get("cwd")
            if not timestamp and data.get("timestamp"):
                timestamp = data.get("timestamp")

            if msg.get("role") == "user":
                msg_num += 1
                total_user += 1
                content = msg.get("content", "")
                text = ""
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    parts = []
                    for c in content:
                        if isinstance(c, dict) and c.get("text"):
                            parts.append(c["text"])
                        elif isinstance(c, dict) and c.get("type") == "image":
                            parts.append("[image]")
                    text = " ".join(parts)

                text = text.replace("\\n", " ").strip()
                if text.startswith("<local-command") or text.startswith("<command"):
                    continue
                if len(text) > 3:
                    wrapped = text[:140]
                    all_messages.append((msg_num, wrapped))

    # Print header
    if name:
        print(f"Session: {{name}}")
    if cwd:
        home = os.path.expanduser("~")
        if cwd.startswith(home):
            cwd = "~" + cwd[len(home):]
        print(f"Folder:  {{cwd}}")
    if timestamp:
        print(f"Started: {{timestamp[:19].replace('T', ' ')}}")
    print(f"Total user messages: {{total_user}}")
    print()

    # Show last N messages (most recent first)
    recent = all_messages[-MAX_PREVIEW:]
    recent.reverse()

    print("Messages (latest first):")
    print()
    for num, text in recent:
        print(f"  {{num}}. {{text}}")

if __name__ == "__main__":
    line = sys.argv[1] if len(sys.argv) > 1 else ""
    if "###" in line:
        parts = line.split("###")
        sid = parts[1].strip() if len(parts) >= 2 else ""
        if sid:
            get_preview(sid)
"""

    with open(script_path, "w") as f:
        f.write(script)
    os.chmod(script_path, 0o755)


def main():
    args = sys.argv[1:]

    show_all = "--all" in args
    if show_all:
        args.remove("--all")

    cwd_filter = None
    if "--here" in args:
        args.remove("--here")
        cwd_filter = os.getcwd()

    limit = 999 if show_all else DEFAULT_LIMIT

    # Gather sessions
    sessions = get_sessions(limit=limit, cwd_filter=cwd_filter)
    if not sessions:
        print("No sessions found.")
        sys.exit(1)

    # Build fzf lines
    # Format: visible_part ###session_id###full_folder_for_search
    lines = []
    for r in sessions:
        date = format_date(r["timestamp"])
        fname = folder_name(r["cwd"])
        msgs = f"{r['msg_count']}msg"
        first_msg = r["first_msg"][:100]
        sid = r["session_id"] or "?"
        ffolder = full_folder(r["cwd"])
        line = f"{date:<8} {fname:<15} {msgs:<7} {first_msg}  ###{sid}###{ffolder}"
        lines.append(line)

    # Write preview helper
    preview_script = tempfile.NamedTemporaryFile(
        mode="w", suffix=".py", delete=False, prefix="claude_browse_preview_"
    )
    preview_script.close()
    write_preview_script(sessions, preview_script.name)

    # Write a small helper that prints "YOLO:" prefix so we can detect it
    yolo_action = f"execute-silent(echo YOLO)+accept"

    try:
        fzf_cmd = [
            "fzf",
            "--ansi",
            "--no-sort",
            "--reverse",
            "--height=90%",
            "--border=rounded",
            "--prompt=Sessions > ",
            "--header=Enter: resume (yolo) | Ctrl-S: resume (safe) | Esc: quit | Shift-Up/Down: scroll preview",
            "--header-first",
            "--delimiter=###",
            "--with-nth=1",
            "--nth=1,3",
            f"--preview=python3 {preview_script.name} {{}}",
            "--preview-window=right:45%:wrap",
            "--bind=shift-up:preview-up,shift-down:preview-down",
            "--bind=ctrl-s:print(SAFE:)+accept",
        ]

        result = subprocess.run(
            fzf_cmd,
            input="\n".join(lines),
            capture_output=True,
            text=True,
        )

        if result.returncode != 0:
            sys.exit(0)

        output = result.stdout.strip()
        if not output or "###" not in output:
            sys.exit(0)

        # Default is yolo (--dangerously-skip-permissions)
        # Ctrl-S prints "SAFE:" to opt INTO safe mode
        yolo = True  # default
        if output.startswith("SAFE:"):
            yolo = False
            output = output[5:]

        # Handle multi-line output
        output_lines = output.strip().split("\n")
        if len(output_lines) > 1:
            if "SAFE:" in output_lines[0] and "###" not in output_lines[0]:
                yolo = False
                output = output_lines[-1]
            else:
                output = output_lines[-1]

        parts = output.split("###")
        session_id = parts[1].strip() if len(parts) >= 2 else ""

        session = next((s for s in sessions if s["session_id"] == session_id), None)
        if not session:
            print(f"Session not found: {session_id}")
            sys.exit(1)

        cwd = session.get("cwd")
        if not cwd or not os.path.isdir(cwd):
            print(f"Original folder no longer exists: {cwd}")
            print(f"Try: claude --resume {session_id}")
            sys.exit(1)

        cmd = ["claude", "--resume", session_id]
        if yolo:
            cmd.append("--dangerously-skip-permissions")

        mode = " (yolo)" if yolo else ""
        print(f"Resuming{mode} in {folder_name(cwd)}...")
        os.chdir(cwd)
        os.execvp("claude", cmd)

    finally:
        os.unlink(preview_script.name)


if __name__ == "__main__":
    main()
