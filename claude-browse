#!/usr/bin/env python3
"""Thin shim for direct-script (git clone) usage.

Delegates to claude_browse.browse:main. When installed via `pip install`, the
entry point in pyproject.toml replaces this shim — end users never see it.
"""

import os
import sys

# Resolve the symlink so the shim still finds the package when install.sh
# links it into ~/.local/bin/
_HERE = os.path.dirname(os.path.realpath(__file__))
if _HERE not in sys.path:
    sys.path.insert(0, _HERE)

from claude_browse.browse import main  # noqa: E402

if __name__ == "__main__":
    main()
