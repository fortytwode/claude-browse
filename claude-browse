#!/usr/bin/env python3
"""
Interactive Claude Code session browser.

Browse all sessions in a fuzzy-searchable list with a preview pane.
Arrow keys to navigate, type to filter, Enter to resume.

Usage:
    claude-browse              # Browse recent 100 sessions
    claude-browse --all        # Browse ALL sessions
    claude-browse --here       # Only sessions from the current directory
    claude-browse --yolo       # Resume with --dangerously-skip-permissions
"""

import sys
import os
import json
import glob
import subprocess
import tempfile
from datetime import datetime, timezone, timedelta

SESSIONS_DIR = os.path.expanduser("~/.claude/projects")
DEFAULT_LIMIT = 100


def get_session_info(jsonl_path):
    """Extract session metadata from a session file."""
    first_user_msg = None
    session_id = None
    timestamp = None
    cwd = None
    name = None
    msg_count = 0

    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                try:
                    data = json.loads(line.strip())
                except json.JSONDecodeError:
                    continue

                msg = data.get("message", data)
                msg_type = data.get("type", "")

                if msg_type == "summary":
                    name = data.get("sessionName")

                if not session_id and data.get("sessionId"):
                    session_id = data.get("sessionId")
                if not cwd and data.get("cwd"):
                    cwd = data.get("cwd")
                if not timestamp and data.get("timestamp"):
                    timestamp = data.get("timestamp")

                if msg.get("role") == "user":
                    msg_count += 1
                    if not first_user_msg:
                        content = msg.get("content", "")
                        if isinstance(content, list):
                            for c in content:
                                if isinstance(c, dict) and c.get("text"):
                                    first_user_msg = c["text"]
                                    break
                        elif isinstance(content, str) and len(content) > 3:
                            first_user_msg = content
                elif msg.get("role") == "assistant":
                    msg_count += 1
    except Exception:
        return None

    return {
        "path": jsonl_path,
        "session_id": session_id,
        "first_msg": (first_user_msg or "").replace("\n", " ").strip()[:200],
        "timestamp": timestamp,
        "cwd": cwd,
        "name": name,
        "msg_count": msg_count,
    }


def get_session_preview(jsonl_path, max_messages=8):
    """Extract first N user messages for the preview pane."""
    messages = []
    msg_num = 0

    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                try:
                    data = json.loads(line.strip())
                except json.JSONDecodeError:
                    continue

                msg = data.get("message", data)
                if msg.get("role") == "user":
                    msg_num += 1
                    content = msg.get("content", "")
                    text = ""
                    if isinstance(content, str):
                        text = content
                    elif isinstance(content, list):
                        parts = []
                        for c in content:
                            if isinstance(c, dict) and c.get("text"):
                                parts.append(c["text"])
                            elif isinstance(c, dict) and c.get("type") == "image":
                                parts.append("[image]")
                        text = " ".join(parts)

                    # Clean up
                    text = text.replace("\n", " ").strip()
                    # Skip system/command messages
                    if text.startswith("<local-command") or text.startswith("<command"):
                        continue
                    if len(text) > 3:
                        messages.append(f"  [{msg_num}] {text[:150]}")

                    if len(messages) >= max_messages:
                        break
    except Exception:
        pass

    return messages


def format_date(ts):
    """Format an ISO timestamp into a readable relative date."""
    if not ts:
        return "???       "
    try:
        dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        diff = now - dt

        if diff.total_seconds() < 3600:
            return f"{int(diff.total_seconds() / 60)}m ago    "
        elif diff.total_seconds() < 86400:
            return f"{int(diff.total_seconds() / 3600)}h ago    "
        elif diff.days < 7:
            return dt.strftime("%-b %d     ")
        elif diff.days < 365:
            return dt.strftime("%-b %d     ")
        else:
            return dt.strftime("%b %Y    ")
    except Exception:
        return ts[:10]


def format_cwd(cwd):
    """Shorten the working directory for display."""
    if not cwd:
        return "?"
    home = os.path.expanduser("~")
    if cwd.startswith(home):
        short = cwd[len(home):]
        short = short.replace("/team-operations/", "/")
        short = short.replace("/content-marketing/", "/content/")
        short = short.replace("/team-planning/", "/planning/")
        short = short.replace("/team-management/", "/mgmt/")
        short = short.replace("/clients/", "/")
        return "~" + short
    return cwd


def get_sessions(limit=DEFAULT_LIMIT, cwd_filter=None):
    """Get sessions sorted by recency."""
    pattern = os.path.join(SESSIONS_DIR, "*", "*.jsonl")
    all_files = glob.glob(pattern)
    main_sessions = [f for f in all_files if "/subagents/" not in f]
    main_sessions.sort(key=lambda f: os.path.getmtime(f), reverse=True)

    results = []
    for filepath in main_sessions[:limit * 3]:
        info = get_session_info(filepath)
        if info and info["first_msg"]:
            if cwd_filter and not (info.get("cwd") or "").startswith(cwd_filter):
                continue
            results.append(info)
        if len(results) >= limit:
            break

    results.sort(key=lambda x: x.get("timestamp") or "", reverse=True)
    return results


def write_preview_script(sessions, script_path):
    """Write a helper script that fzf calls to generate previews."""
    # Build a mapping of session_id -> jsonl_path
    mapping = {s["session_id"]: s["path"] for s in sessions if s.get("session_id")}

    script = f"""#!/usr/bin/env python3
import sys
import json
import os

MAPPING = {json.dumps(mapping)}

def get_preview(session_id):
    path = MAPPING.get(session_id)
    if not path or not os.path.exists(path):
        print("Session file not found.")
        return

    messages = []
    msg_num = 0
    cwd = None
    timestamp = None
    name = None

    with open(path, "r") as f:
        for line in f:
            try:
                data = json.loads(line.strip())
            except json.JSONDecodeError:
                continue

            msg = data.get("message", data)
            msg_type = data.get("type", "")

            if msg_type == "summary" and data.get("sessionName"):
                name = data.get("sessionName")
            if not cwd and data.get("cwd"):
                cwd = data.get("cwd")
            if not timestamp and data.get("timestamp"):
                timestamp = data.get("timestamp")

            if msg.get("role") == "user":
                msg_num += 1
                content = msg.get("content", "")
                text = ""
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    parts = []
                    for c in content:
                        if isinstance(c, dict) and c.get("text"):
                            parts.append(c["text"])
                        elif isinstance(c, dict) and c.get("type") == "image":
                            parts.append("[image]")
                    text = " ".join(parts)

                text = text.replace("\\n", " ").strip()
                if text.startswith("<local-command") or text.startswith("<command"):
                    continue
                if len(text) > 3:
                    # Wrap long lines
                    wrapped = text[:120]
                    messages.append(f"  {{msg_num}}. {{wrapped}}")

                if len(messages) >= 12:
                    break

    # Print header
    if name:
        print(f"Session: {{name}}")
    if cwd:
        home = os.path.expanduser("~")
        if cwd.startswith(home):
            cwd = "~" + cwd[len(home):]
        print(f"Folder:  {{cwd}}")
    if timestamp:
        print(f"Started: {{timestamp[:19].replace('T', ' ')}}")
    print(f"Messages shown: {{len(messages)}}")
    print()
    print("User messages:")
    print()
    for m in messages:
        print(m)

if __name__ == "__main__":
    # fzf passes the selected line via stdin or argument
    line = sys.argv[1] if len(sys.argv) > 1 else ""
    if "###" in line:
        parts = line.split("###")
        sid = parts[1].strip() if len(parts) >= 2 else ""
        if sid:
            get_preview(sid)
"""

    with open(script_path, "w") as f:
        f.write(script)
    os.chmod(script_path, 0o755)


def main():
    args = sys.argv[1:]

    yolo = "--yolo" in args
    if yolo:
        args.remove("--yolo")

    show_all = "--all" in args
    if show_all:
        args.remove("--all")

    cwd_filter = None
    if "--here" in args:
        args.remove("--here")
        cwd_filter = os.getcwd()

    limit = 999 if show_all else DEFAULT_LIMIT

    # Gather sessions
    sessions = get_sessions(limit=limit, cwd_filter=cwd_filter)
    if not sessions:
        print("No sessions found.")
        sys.exit(1)

    # Build fzf lines
    # Format: visible part ### hidden session_id ### hidden searchable folder
    # fzf searches the full line (including hidden parts after ###)
    # but --with-nth=1 only DISPLAYS the part before the first ###
    lines = []
    for r in sessions:
        date = format_date(r["timestamp"])
        folder = format_cwd(r["cwd"])
        # Extract just the last folder component for compact display
        folder_short = folder.rstrip("/").rsplit("/", 1)[-1] if "/" in folder else folder
        msgs = f"{r['msg_count']}msg"
        name_str = f'"{r["name"]}" ' if r.get("name") else ""
        first_msg = r["first_msg"][:100]
        sid = r["session_id"] or "?"
        # The full folder path goes in the searchable area after ###
        # so typing "musopia" or "sales" or "maxrewards" will match
        line = f"{date} {folder_short:<18} {msgs:<7} {name_str}{first_msg}  ###{sid}###{folder}"
        lines.append(line)

    # Write preview helper script
    preview_script = tempfile.NamedTemporaryFile(
        mode="w", suffix=".py", delete=False, prefix="claude_browse_preview_"
    )
    preview_script.close()
    write_preview_script(sessions, preview_script.name)

    try:
        fzf_cmd = [
            "fzf",
            "--ansi",
            "--no-sort",
            "--reverse",
            "--height=90%",
            "--border=rounded",
            "--prompt=Sessions > ",
            "--header=  When       Folder             Msgs   Prompt",
            "--header-first",
            "--delimiter=###",
            "--with-nth=1",        # display only the part before first ###
            "--nth=1,3",           # search both visible text AND hidden folder path
            f"--preview=python3 {preview_script.name} {{}}",
            "--preview-window=right:45%:wrap",
        ]

        result = subprocess.run(
            fzf_cmd,
            input="\n".join(lines),
            capture_output=True,
            text=True,
        )

        if result.returncode != 0:
            sys.exit(0)

        selected = result.stdout.strip()
        if not selected or "###" not in selected:
            sys.exit(0)

        # Format is: visible###session_id###folder
        parts = selected.split("###")
        session_id = parts[1].strip() if len(parts) >= 2 else ""

        session = next((s for s in sessions if s["session_id"] == session_id), None)
        if not session:
            print(f"Session not found: {session_id}")
            sys.exit(1)

        cwd = session.get("cwd")
        if not cwd or not os.path.isdir(cwd):
            print(f"Original folder no longer exists: {cwd}")
            print(f"Try: claude --resume {session_id}")
            sys.exit(1)

        cmd = ["claude", "--resume", session_id]
        if yolo:
            cmd.append("--dangerously-skip-permissions")

        print(f"Resuming in {format_cwd(cwd)}...")
        os.chdir(cwd)
        os.execvp("claude", cmd)

    finally:
        os.unlink(preview_script.name)


if __name__ == "__main__":
    main()
